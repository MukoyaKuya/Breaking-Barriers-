# --- Django Core ---
DEBUG=False
SECRET_KEY=generate-a-secure-random-key-here
ALLOWED_HOSTS=bb-international.org,www.bb-international.org
CSRF_TRUSTED_ORIGINS=https://bb-international.org,https://www.bb-international.org

# --- HostPinnacle MySQL Database ---
# Create these in cPanel -> MySQL Databases
DB_NAME=your_cpanel_db_name
DB_USER=your_cpanel_db_user
DB_PASS=your_cpanel_db_password
DB_HOST=localhost
DB_PORT=3306

# --- Storage Configuration ---
# Set to 'True' to use HostPinnacle's Unlimited NVMe SSD Disk (Recommended)
USE_LOCAL_STORAGE=True

# Static/Media paths (usually default works with Passenger)
# STATIC_ROOT=/home/youruser/Breaking-Barriers/staticfiles
# MEDIA_ROOT=/home/youruser/Breaking-Barriers/media

# --- Security ---
# Set to 'True' after ensuring SSL is working to force HTTPS
# SECURE_SSL_REDIRECT=True

# --- Cache (Optional) ---
# REDIS_URL=redis://127.0.0.1:6379/1
